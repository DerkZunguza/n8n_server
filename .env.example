# =============================================================
# N8N - Variáveis de Ambiente
# COPIE este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no Git!
# =============================================================

# Subdomínio onde o N8N será acessível
# Exemplo: n8n.meudominio.com
N8N_SUBDOMAIN=n8n.eurekaplatformapi.xyz

# Senha do PostgreSQL (use uma senha forte!)
POSTGRES_PASSWORD=SenhaMuitoForteAqui123!@#

# Chave de encriptação do N8N (gere uma string aleatória longa)
# Gerar: openssl rand -hex 32
N8N_ENCRYPTION_KEY=troque_por_uma_string_aleatoria_de_64_caracteres_aqui_000000000000
